{
  "semantic": {
    "background": {
      "primary":   { "$value": "{color.grey.900}", "$type": "color" },
      "secondary": { "$value": "{color.grey.700}", "$type": "color" },
      "tertiary":  { "$value": "{color.grey.500}", "$type": "color" }
    },
    "text": {
      "primary":   { "$value": "{color.grey.0}",   "$type": "color" },
      "secondary": { "$value": "{color.grey.350}", "$type": "color" },
      "tertiary":  { "$value": "{color.grey.450}", "$type": "color" },
      "inverse":   { "$value": "{color.grey.900}", "$type": "color" }
    },
    "border": {
      "default": { "$value": "{color.grey.700}", "$type": "color" },
      "strong":  { "$value": "{color.grey.500}", "$type": "color" }
    },
    "action": {
      "primary":        { "$value": "{color.grey.0}",   "$type": "color" },
      "primaryContent": { "$value": "{color.grey.900}", "$type": "color" },
      "secondary":      { "$value": "{color.grey.700}", "$type": "color" },
      "disabled":       { "$value": "{color.grey.700}", "$type": "color" },
      "disabledContent":{ "$value": "{color.grey.500}", "$type": "color" }
    },
    "status": {
      "error":   { "$value": "{color.error.500}",   "$type": "color" },
      "warning": { "$value": "{color.warning.500}", "$type": "color" },
      "success": { "$value": "{color.success.500}", "$type": "color" },
      "info":    { "$value": "{color.info.500}",    "$type": "color" }
    },
    "tabBar": {
      "selected":   { "$value": "{color.grey.0}",   "$type": "color" },
      "unselected": { "$value": "{color.grey.450}", "$type": "color" },
      "background": { "$value": "{color.grey.900}", "$type": "color" },
      "border":     { "$value": "{color.grey.700}", "$type": "color" }
    }
  }
}
